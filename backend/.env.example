# Copy this file to `.env` and add ONE provider key to enable live generation —
# the planner (goal → plan) and the segment summaries are written by your chosen
# model under structured outputs. Without a key the app uses deterministic
# fallbacks and still runs fully end-to-end.
#
# The app is AI-provider-agnostic. Set the key for the provider you want; the
# provider is auto-detected from whichever key is present. `.env` is gitignored —
# each tester supplies their own key.

# ── Pick one (auto-detected in this order: Anthropic → OpenAI → Gemini) ───────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here       # Claude — https://console.anthropic.com/
# OPENAI_API_KEY=sk-your-openai-key                # GPT    — https://platform.openai.com/
# GEMINI_API_KEY=your-gemini-key                   # Gemini — https://aistudio.google.com/  (GOOGLE_API_KEY also works)

# ── Optional overrides ────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic | openai | gemini | openai_compatible   # force a provider
# LLM_MODEL=...    # override the default model (defaults: claude-opus-4-8 / gpt-5.1 / gemini-2.5-flash)
# LLM_BASE_URL=... # an OpenAI-compatible endpoint → routes to the openai_compatible adapter
# LLM_PRICE_IN= / LLM_PRICE_OUT=   # $ per 1M tokens, to price an unlisted model in the
#                                  # approval gate's cost estimate (else a best-effort default)

# ── Example: any OpenAI-compatible endpoint (Ollama / Groq / OpenRouter / vLLM) ─
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3
# OPENAI_API_KEY=ollama        # compatible endpoints still read the OpenAI key var
