# Copy this file to `.env` and add your own Anthropic API key to enable live
# Claude — the planner (goal → plan) and the segment summaries are generated by
# claude-opus-4-8 under structured outputs. Without a key the app uses
# deterministic fallbacks and still runs fully end-to-end.
#
# Get a key at https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
